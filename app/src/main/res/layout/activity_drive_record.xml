<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5"
        android:orientation="vertical">

        <!-- 제목 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back_arrow" />

            <TextView
                android:id="@+id/tv_page_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" 운행 기록 확인"
                android:fontFamily="@font/pretendard_bold"
                android:textSize="18sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="4dp"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">
            <!-- 제목 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvDrivingScoreTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="최종 점수"
                    android:fontFamily="@font/pretendard_bold"
                    android:textSize="16sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvViewMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="금주 운행 기록 →"
                    android:fontFamily="@font/pretendard_medium"
                    android:textSize="14sp"
                    android:textColor="#888888" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <!-- 운행 점수 영역 -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center">
                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/item_circular_gauge_bar"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:progress="60"
                        app:indicatorColor="@color/main"
                        app:indicatorDirectionCircular="clockwise"
                        app:indicatorSize="110dp"
                        app:trackColor="@color/gray_light"
                        app:trackThickness="14dp" />

                    <TextView
                        android:id="@+id/tv_circular_gauge_percentage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="60점"
                        android:fontFamily="@font/pretendard_bold"
                        android:textColor="@color/black"
                        android:textSize="20sp" />
                </FrameLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="8dp">
                        <!-- 졸음운전 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:layout_marginEnd="16dp">

                            <ImageView
                                android:layout_width="5dp"
                                android:layout_height="19dp"
                                android:src="@drawable/bg_button"
                                android:layout_marginEnd="5dp"
                                app:tint="#449fd5"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="졸음운전"
                                android:fontFamily="@font/pretendard_regular"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tv_sleep"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="right"
                                android:text="1회"
                                android:fontFamily="@font/pretendard_bold"
                                android:textSize="14sp" />
                        </LinearLayout>
                        <!-- 급가속 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="bottom">

                            <ImageView
                                android:layout_width="5dp"
                                android:layout_height="19dp"
                                android:src="@drawable/bg_button"
                                android:layout_marginEnd="5dp"
                                android:layout_marginStart="8dp"
                                app:tint="#498bd0"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="급가속"
                                android:fontFamily="@font/pretendard_regular"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tv_over_speed"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="right"
                                android:text="1회"
                                android:fontFamily="@font/pretendard_bold"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">
                        <!-- 급제동 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:layout_marginEnd="16dp">
                            <ImageView
                                android:layout_width="5dp"
                                android:layout_height="19dp"
                                android:src="@drawable/bg_button"
                                android:layout_marginEnd="5dp"
                                app:tint="#555cc1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="이상행동"
                                android:fontFamily="@font/pretendard_regular"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tv_abnormal"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="right"
                                android:text="1회"
                                android:fontFamily="@font/pretendard_bold"
                                android:textSize="14sp" />
                        </LinearLayout>
                        <!-- 이상행동 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="bottom">

                            <ImageView
                                android:layout_width="5dp"
                                android:layout_height="19dp"
                                android:src="@drawable/bg_button"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="5dp"
                                app:tint="#4f71c8"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="급제동"
                                android:fontFamily="@font/pretendard_regular"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tv_under_speed"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="right"
                                android:text="1회"
                                android:fontFamily="@font/pretendard_bold"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <!-- 메인 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">
            <!-- 점수 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_drive_card_no_padding"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="노선 / 차량 번호"
                    android:textSize="12sp"
                    android:fontFamily="@font/pretendard_semibold"
                    android:paddingTop="6dp"/>

                <!-- 노선 번호 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tvRouteNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1550-1번"
                        android:textColor="@color/gray"
                        android:fontFamily="@font/pretendard_regular"
                        android:textSize="16sp"
                        android:padding="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/"
                        android:fontFamily="@font/pretendard_regular"
                        android:textColor="@color/gray"
                        android:textSize="16sp"
                        android:paddingVertical="4dp"/>

                    <TextView
                        android:id="@+id/tvVehicleNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="157거 1535"
                        android:fontFamily="@font/pretendard_regular"
                        android:textColor="@color/gray"
                        android:textSize="16sp"
                        android:padding="4dp"/>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="날짜"
                    android:fontFamily="@font/pretendard_semibold"
                    android:textSize="12sp"
                    android:paddingTop="6dp" />
                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2025-08-10"
                    android:fontFamily="@font/pretendard_regular"
                    android:textColor="@color/gray"
                    android:textSize="16sp"
                    android:padding="4dp"/>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD" />
                <!-- 실제 도착 시간 값  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:paddingTop="6dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_weight="1">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="실제 출발 시간"
                            android:textSize="12sp"
                            android:fontFamily="@font/pretendard_semibold" />
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#DDDDDD" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_weight="1">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="실제 도착 시간"
                            android:fontFamily="@font/pretendard_semibold"
                            android:textSize="12sp" />

                    </LinearLayout>
                </LinearLayout>
                <!-- 실제 도착 시간 값  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_weight="1">
                        <TextView
                            android:id="@+id/tvDepartureTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00:00"
                            android:fontFamily="@font/pretendard_regular"
                            android:textColor="@color/gray"
                            android:textSize="16sp"
                            android:padding="4dp"/>
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#DDDDDD"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_weight="1">

                        <TextView
                            android:id="@+id/tvArrivalTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00:00"
                            android:fontFamily="@font/pretendard_regular"
                            android:textColor="@color/gray"
                            android:textSize="16sp"
                            android:padding="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:elevation="4dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"
            android:weightSum="5">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="3"
                android:background="@drawable/bg_drive_card_left_rounded">
                <!--지도 추가-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="1dp"
                    android:background="@drawable/bg_card_left_rounded"
                    android:clipToOutline="true"
                    >
                    <!--지도 추가-->
                    <com.kakao.vectormap.MapView
                        android:id="@+id/map_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        tools:background="@color/gray_light" />

                </LinearLayout>

            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:background="@drawable/bg_drive_card_right_rounded"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="8dp">
                <TextView
                    android:id="@+id/tvEvents"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="경고 없음"
                    android:textSize="16sp"
                    android:textColor="@color/gray"
                    android:gravity="center"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEvents"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:overScrollMode="never"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
