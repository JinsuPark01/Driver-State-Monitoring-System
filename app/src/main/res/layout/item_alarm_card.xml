<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="@drawable/bg_drive_card">

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 배차 날짜 -->
        <TextView
            android:id="@+id/tvDispatchDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2025-09-30 09:00"
            android:textSize="16sp"
            android:layout_marginEnd="6dp"
            android:textStyle="bold"/>

        <!-- 알림 메시지 -->
        <TextView
            android:id="@+id/tvNotificationMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="신규 배차 추가"
            android:textSize="16sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/tvNotificationIsRead"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="읽음"
            android:textSize="14sp"
            android:textColor="#333"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvNotificationCreatedAt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2025-09-28 23:41 작성"
        android:textSize="12sp"
        android:textColor="@color/gray_light"
        android:layout_marginTop="4dp"
        />
</LinearLayout>
